# ---- Copy to .env and fill in. The app reads these at runtime. ----

# REQUIRED for real model output in the local/hybrid profile.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which config profile to load: local | hybrid | aws
ATF_PROFILE=local

# Optional overrides
# ATF_LLM_MODEL=openai/gpt-4o-mini
# ATF_VISION_MODEL=openai/gpt-4o-mini
# ATF_EMBED_PROVIDER=local          # local | openrouter | bedrock
# ATF_PORT=8077
# ATF_DATA_DIR=./storage

# ---- Neo4j (only if graph_store.provider = neo4j) ----
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=neo4j

# ---- AWS (only for the aws profile) ----
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
